# BUG_RESOLUTION_PLAN [PHASE 8][MODIFICATION]
# Citations: BUG_RESOLUTION_PLAN.md:1350-1363.
# Ignore only generated fuzz state. Checked-in read-only seeds live under
# fuzz/seeds/ and remain visible; source targets and configuration remain visible.
fuzz/artifacts/
fuzz/corpus/
fuzz/coverage/
fuzz/target/

# Generated by Cargo
# will have compiled files and executables
debug
target
test/scenarios/**/Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# macOS Finder metadata must never be committed
.DS_Store

# MSVC Windows builds can generate these debugging-information files
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/
